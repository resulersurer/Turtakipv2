# Neon pooled connection string for the app/runtime.
# Use the Prisma/pooled URL from Neon and keep sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Neon direct connection string for Prisma migrations.
# Use the direct/non-pooled URL from Neon and keep sslmode=require.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Public application URL.
# Local development: http://localhost:3000
# Production: https://your-vercel-domain.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
